# Clave API de Anthropic — obtener en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ruta al storage (Google Drive recomendado para sincronizar entre Macs)
# Ejemplo macOS con Google Drive:
# STORAGE_PATH=/Users/TU_USUARIO/Library/CloudStorage/GoogleDrive-tu@email.com/My Drive/kobber/storage
# Por defecto usa ./storage (local)
STORAGE_PATH=./storage
